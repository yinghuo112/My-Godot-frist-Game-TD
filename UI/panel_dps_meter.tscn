[gd_scene format=3]

[ext_resource type="Script" path="res://UI/panel_dps_meter.gd" id="1"]

[sub_resource type="StyleBoxFlat" id="bg"]
bg_color = Color(0.08, 0.08, 0.15, 0.88)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[node name="DPSMeter" type="PanelContainer"]
anchors_preset = 0
offset_left = 8
offset_top = 44
custom_minimum_size = Vector2(180, 0)
mouse_filter = 1
theme_override_styles/panel = SubResource("bg")
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="HeaderBtn" type="Button" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 12
text = "📊 DPS统计  ▲"
flat = true

[node name="ListBox" type="VBoxContainer" parent="VBox"]
layout_mode = 2

[node name="ToggleBtn" type="Button" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "显示全部 ▽"
flat = true

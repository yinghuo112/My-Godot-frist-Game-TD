[gd_resource type="Resource" script_class="SkillBook" format=3]

[ext_resource type="Script" path="res://SkillSystem/core/skill_book.gd" id="1_book"]
[ext_resource type="Script" path="res://SkillSystem/core/skill_base.gd" id="2_base"]
[ext_resource type="Script" path="res://SkillSystem/skills/slow_skill.gd" id="3_slow"]

[sub_resource type="Resource" script_class="SkillBase" id="s_base_shot"]
script = ExtResource("2_base")
name = "重炮轰击"
tags = ["通用", "弹道"]
description = "提高基础攻击力。"
max_level = 3
prerequisites = []
required_tower_level = 1
gold_cost = 0
level_table = [{"damage":10.0,"cost_points":1,"cost_prof":0,"special":""},{"damage":20.0,"cost_points":1,"cost_prof":60,"special":""},{"damage":35.0,"cost_points":2,"cost_prof":180,"special":"暴击率+5%"}]

[sub_resource type="Resource" script_class="SlowSkill" id="s_slow"]
script = ExtResource("3_slow")
name = "减速弹"
tags = ["诅咒"]
description = "命中后降低目标移动速度，持续 3 秒。"
max_level = 3
prerequisites = [0]
required_tower_level = 2
gold_cost = 40
level_table = [{"damage":0.0,"cost_points":1,"cost_prof":0,"special":""},{"damage":0.0,"cost_points":1,"cost_prof":80,"special":"减速+5%"},{"damage":0.0,"cost_points":2,"cost_prof":200,"special":"减速+10%"}]
slow_ratio = 0.4
base_duration = 3.0

[resource]
script = ExtResource("1_book")
name = "炮塔手册"
tags = ["弹道", "诅咒"]
skills = [SubResource("s_base_shot"), SubResource("s_slow")]